{
  "hosting": {
    "site": "architecture-glasshood",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
